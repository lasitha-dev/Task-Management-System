{
  "name": "task-management-system",
  "version": "1.0.0",
  "description": "Secure Microservice-Based Task Management System",
  "scripts": {
    "start": "./dev-start.sh",
    "stop": "./dev-stop.sh",
    "docker:start": "docker-compose up --build -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "install:all": "npm run install:api && npm run install:user && npm run install:task && npm run install:user-frontend && npm run install:task-frontend",
    "install:api": "cd api-gateway && npm install",
    "install:user": "cd user-management && npm install",
    "install:task": "cd task-management && npm install",
    "install:user-frontend": "cd user-management/frontend && npm install",
    "install:task-frontend": "cd task-management/frontend && npm install"
  },
  "keywords": [
    "microservices",
    "task-management",
    "mern-stack",
    "docker"
  ],
  "author": "SLIIT SE4010",
  "license": "MIT"
}
