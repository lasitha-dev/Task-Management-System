{
    "name": "task-management",
    "version": "1.0.0",
    "description": "Task Management Microservice - Core Kanban task lifecycle (CRUD, drag-and-drop, status tracking)",
    "main": "src/app.js",
    "scripts": {
        "start": "node src/app.js",
        "dev": "nodemon src/app.js",
        "test": "jest --coverage",
        "generate-token": "node src/utils/generateToken.js"
    },
    "dependencies": {
        "axios": "^1.7.2",
        "cors": "^2.8.5",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "express-validator": "^7.2.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.10.1"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "mongodb-memory-server": "^10.4.3",
        "nodemon": "^3.1.9",
        "supertest": "^7.0.0"
    },
    "jest": {
        "testEnvironment": "node",
        "testTimeout": 30000,
        "testMatch": [
            "**/tests/**/*.test.js"
        ]
    }
}
